    "lp-adcrunch-new-how-it-works": {
      "type": "lp-adcrunch-new-how-it-works",
      "blocks": {
        "block_lp-adcrunch-new-how-it-works_0": {
          "type": "step",
          "settings": {
            "title": "Section",
            "text": "Part your hair horizontally at\nthe nape. Clip the top layer\nout of the way. The base\nsection is where the clips sit."
          }
        },
        "block_lp-adcrunch-new-how-it-works_1": {
          "type": "step",
          "settings": {
            "title": "Clip",
            "text": "Press the ultra-narrow weft\nagainst your roots. Snap the\nclips closed. No pulling, no\nforce — they grip gently."
          }
        },
        "block_lp-adcrunch-new-how-it-works_2": {
          "type": "step",
          "settings": {
            "title": "Release",
            "text": "Let down the top layer of\nyour natural hair over the\nweft. That's it. The clip is\nhidden. The volume is there."
