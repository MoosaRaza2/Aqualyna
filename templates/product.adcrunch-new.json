    "lp-adcrunch-new-the-shift": {
      "type": "lp-adcrunch-new-the-shift",
      "blocks": {
        "block_lp-adcrunch-new-the-shift_0": {
          "type": "card",
          "settings": {
            "title": "Before",
            "items": "Angling your head in every photo before you'll let anyone take it\nA mental blacklist of hairstyles that expose the problem\nDry shampoo, mousse, root spray — gone by 10am\n\"I feel less feminine. Less myself.\"\nManaging a problem, every single day\n\"I can't find anything that works.\" — still buying, still hoping"
          }
        },
        "block_lp-adcrunch-new-the-shift_1": {
          "type": "card",
          "settings": {
            "title": "After",
            "items": "Actually posing for photos — from any angle\nPutting your hair up without calculating the risk\nVolume that's there at noon, 3pm, 6pm — all day\n\"People keep asking me what I'm doing differently.\"\nKeeping a secret other women want to know\n\"I don't even think about my hair anymore.\" — the highest outcome."
          }
        }
      },
      "block_order": [
        "block_lp-adcrunch-new-the-shift_0",
        "block_lp-adcrunch-new-the-shift_1"
      ],
      "settings": {
        "tagline": "The shift",
        "heading": "The goal isn't hair.\nThe goal is to stop the negotiation.",
        "description": "Not \"love my hair.\" Not \"feel like a model.\" Just get ready, look in the mirror, and feel good enough to move on to the rest of the day."
      }
    },
    "lp-adcrunch-new-how-it-stacks-up": {
      "type": "lp-adcrunch-new-how-it-stacks-up",
