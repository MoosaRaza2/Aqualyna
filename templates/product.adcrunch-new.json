    "lp-adcrunch-new-if-you-have-fine": {
      "type": "lp-adcrunch-new-if-you-have-fine",
      "blocks": {
        "block_lp-adcrunch-new-if-you-have-fine_0": {
          "type": "card",
          "settings": {
            "emoji": "🧴",
            "title": "The product graveyard under your sink",
            "body": "Every purchase came with hope. Root spray. Thickening shampoo. Biotin supplements. Minoxidil. None of them made a visible difference that lasted the day. You kept buying because you kept hoping. Your hope per product has dropped — but you haven't stopped looking.",
            "quote": "\"I've tried root sprays, volumizing mousse, dry shampoo, thickening serums. All of them. Most provide about 45 minutes of lift before gravity wins.\""
          }
        },
        "block_lp-adcrunch-new-if-you-have-fine_1": {
          "type": "card",
          "settings": {
            "emoji": "📸",
            "title": "The photo calculation. Every time.",
            "body": "You angle your head. You avoid overhead lights. You don't tag yourself in group shots where your part is visible from above. You have a mental blacklist of hairstyles you don't wear — ponytails show how thin it is from behind, updos expose the crown, parted down the middle shows the widening part line.",
            "quote": "\"I find myself second-guessing my appearance before heading out, wondering if my hair looks too thin or if people will notice.\""
          }
        },
        "block_lp-adcrunch-new-if-you-have-fine_2": {
          "type": "card",
          "settings": {
            "emoji": "🕐",
            "title": "The mental overhead nobody talks about",
            "body": "Every morning, every photo, every windy day, every overhead light — you're doing a calculation. Is it showing? Does it look okay? Should I fix it? That is exhausting. And invisible. Nobody around you knows you're doing it.",
            "quote": "\"I always have to think about it. I can't just put my hair up and go.\""
          }
        },
        "block_lp-adcrunch-new-if-you-have-fine_3": {
          "type": "card",
          "settings": {
            "emoji": "💔",
            "title": "The identity shift that snuck up on you",
            "body": "You didn't choose this. Your hair changed — through perimenopause, stress, medication, or just time — and you lost something you didn't know you were attached to until it was gone. It's not about vanity. It's about looking how you're supposed to look, feeling like the version of yourself you recognize.",
            "quote": "\"It makes me feel less feminine. Less myself. It makes me feel older than I am.\""
          }
        }
      },
      "block_order": [
        "block_lp-adcrunch-new-if-you-have-fine_0",
        "block_lp-adcrunch-new-if-you-have-fine_1",
        "block_lp-adcrunch-new-if-you-have-fine_2",
        "block_lp-adcrunch-new-if-you-have-fine_3"
      ],
      "settings": {
        "eyebrow": "If you have fine or thinning hair, you already know",
        "heading": "You've tried everything.\nEverything stopped working by noon.",
        "subtext": "Root spray. Volumizing mousse. Dry shampoo. Thickening serum. You've spent hundreds of dollars on the hope that this one will be different. It lifts for 45 minutes. Then gravity wins. Again."
      }
    },
