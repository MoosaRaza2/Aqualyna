{{ 'lp-adcrunch-new-the-real-questions.css' | asset_url | stylesheet_tag }}

<section class="lp-the-real-questions" id="lp-section-{{ section.id }}">
  <div class="lp-the-real-questions__container">
    <header class="lp-the-real-questions__header">
      {% if section.settings.subheader != blank %}
        <p class="lp-the-real-questions__subheader">{{ section.settings.subheader }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="lp-the-real-questions__heading">{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
    </header>

    <div class="lp-the-real-questions__grid">
      {% for block in section.blocks %}
        <div class="lp-the-real-questions__card" {{ block.shopify_attributes }}>
          <div class="lp-the-real-questions__card-icon">{{ block.settings.icon }}</div>
          <div class="lp-the-real-questions__card-content">
            {% if block.settings.title != blank %}
              <h3 class="lp-the-real-questions__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <div class="lp-the-real-questions__card-description">
                {{ block.settings.description | newline_to_br }}
              </div>
            {% endif %}
            {% if block.settings.answer != blank %}
              <div class="lp-the-real-questions__card-answer-box">
                <div class="lp-the-real-questions__card-answer">
                  {{ block.settings.answer | newline_to_br }}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Objection Busting",
  "settings": [
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader",
      "default": "The real questions"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "You've thought about this.\nHere's the honest answer to each one."
    }
  ],
  "blocks": [
    {
      "type": "question_card",
      "name": "Question Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji Icon",
          "default": "👁️"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Objection Text",
          "default": "\"The clips will show through my thin hair. I'll be mortified.\""
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Explanation",
          "default": "This is the fear that has kept more fine-hair women from trying extensions than any other. It's specific, it's vivid, and it's understandable. You already self-manage the visibility of your thinning hair every day. The last thing you need is to draw more attention to it."
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer/Reframe",
          "default": "The ultra-narrow weft was designed specifically to solve this. A thinner base means less coverage needed from above — so even sparse hair can hide it completely. Every reviewer who was terrified of this has said the same thing: \"I've gone through my hair looking for it. Can't find it.\" That's the point."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Objection Busting",
