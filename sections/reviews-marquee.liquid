{%- liquid
  assign animation_speed = section.settings.animation-speed
  assign animation_direction = section.settings.animation-direction
  assign pause_on_hover = section.settings.pause-on-hover
  assign bg_color = section.settings.background-color
  assign spacing_above = section.settings.spacing-above
  assign spacing_below = section.settings.spacing-below
  assign heading = section.settings.heading
-%}

{{ 'reviews-marquee.css' | asset_url | stylesheet_tag }}

{%- capture reviews_html -%}
  {%- for block in section.blocks -%}
    <div class="reviews-marquee--card" {{ block.shopify_attributes }}>
      <p class="reviews-marquee--text">{{ block.settings.review_text }}</p>
      <div class="reviews-marquee--footer">
        <span class="reviews-marquee--name">{{ block.settings.customer_name }}</span>
        <span class="reviews-marquee--stars">★★★★★</span>
      </div>
    </div>
  {%- endfor -%}
{%- endcapture -%}

<div
  class="reviews-marquee--root"
  data-section-id="{{ section.id }}"
  data-background-color="{{ bg_color }}"
  data-hover-pause="{{ pause_on_hover }}"
  data-direction="{{ animation_direction }}"
  data-spacing-above="{{ spacing_above }}"
  data-spacing-below="{{ spacing_below }}"
  style="--reviews-marquee--speed:{{ animation_speed }};"
>
  {%- if heading != blank -%}
    <div class="reviews-marquee--heading">
      <h2>{{ heading }}</h2>
    </div>
  {%- endif -%}

  <div class="reviews-marquee--wrapper">
    {%- for i in (0..5) -%}
      <div class="reviews-marquee--container">
        {{- reviews_html -}}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Reviews marquee",
  "class": "section--reviews-marquee",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "id": "background-color",
      "label": "Background color",
      "type": "select",
      "options": [
        { "label": "None", "value": "none" },
        { "label": "Light", "value": "light" },
        { "label": "Dark", "value": "dark" },
        { "label": "Accent 1", "value": "accent-1" },
        { "label": "Accent 2", "value": "accent-2" }
      ],
      "default": "none"
    },
    {
      "id": "spacing-above",
      "label": "Spacing above",
      "type": "checkbox",
      "default": true
    },
    {
      "id": "spacing-below",
      "label": "Spacing below",
      "type": "checkbox",
      "default": true
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "id": "animation-direction",
      "label": "Direction",
      "type": "select",
      "options": [
        { "label": "Left", "value": "left" },
        { "label": "Right", "value": "right" }
      ],
      "default": "left"
    },
    {
      "id": "animation-speed",
      "label": "Scroll speed",
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "id": "pause-on-hover",
      "label": "Pause on hover",
      "type": "checkbox",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review",
          "default": "Love Aqua hair extensions and the colors they have are amazing!"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name",
          "default": "AMBER BEAL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews marquee",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "Love Aqua hair extensions and the colors they have are amazing!",
            "customer_name": "AMBER BEAL"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "Best hair extensions I have ever used. The quality is unmatched!",
            "customer_name": "JESSICA MILLER"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "So soft and natural looking. I get compliments every single day!",
            "customer_name": "SARAH JOHNSON"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "The color match was perfect and the installation was so easy!",
            "customer_name": "EMILY DAVIS"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["aside"]
  }
}
{% endschema %}
