{% schema %}
{
  "name": "Landing - Hair Difference",
  "settings": [
    { "type": "header", "content": "Images" },
    { "type": "image_picker", "id": "image_desktop", "label": "Main image (desktop)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Main image (mobile)" },

    { "type": "header", "content": "Icons" },
    { "type": "image_picker", "id": "icon_1", "label": "Top icon 1" },
    { "type": "image_picker", "id": "icon_2", "label": "Top icon 2" },
    { "type": "image_picker", "id": "icon_3", "label": "Top icon 3" },
    {
      "type": "select",
      "id": "active_icon",
      "label": "Active top icon",
      "options": [
        { "value": "1", "label": "Icon 1" },
        { "value": "2", "label": "Icon 2" },
        { "value": "3", "label": "Icon 3" }
      ],
      "default": "1"
    },

    { "type": "header", "content": "Callout (updates when icon selected)" },
    { "type": "image_picker", "id": "bubble_icon", "label": "Default bubble image (fallback)" },
    { "type": "image_picker", "id": "bubble_icon_1", "label": "Bubble image for icon 1" },
    { "type": "image_picker", "id": "bubble_icon_2", "label": "Bubble image for icon 2" },
    { "type": "image_picker", "id": "bubble_icon_3", "label": "Bubble image for icon 3" },
    {
      "type": "range",
      "id": "bubble_img_width",
      "label": "Bubble image width (px)",
      "min": 20,
      "max": 120,
      "step": 1,
      "default": 60
    },
    {
      "type": "range",
      "id": "bubble_img_height",
      "label": "Bubble image height (px)",
      "min": 20,
      "max": 120,
      "step": 1,
      "default": 90
    },
    { "type": "textarea", "id": "callout_text_1", "label": "Callout text for icon 1", "default": "Cuticle-aligned\nhuman hair" },
    { "type": "textarea", "id": "callout_text_2", "label": "Callout text for icon 2", "default": "Minimal\nshedding" },
    { "type": "textarea", "id": "callout_text_3", "label": "Callout text for icon 3", "default": "Natural\nshine" }
  ],
  "presets": [
    { "name": "Landing - Hair Difference" }
  ]
}
{% endschema %}

<section id="LandingHairDifference-{{ section.id }}" class="landing-hairdifference">
  <div class="lhd-surface">
    <div class="page-width">
      <div class="lhd-grid">
        <div class="lhd-media" aria-hidden="true">
          <div class="lhd-media__inner">
            {%- if section.settings.image_desktop != blank -%}
              <picture>
                {%- if section.settings.image_mobile != blank -%}
                  <source media="(max-width: 768px)" srcset="{{ section.settings.image_mobile | image_url: width: 1600 }}">
                {%- endif -%}
                <img
                  class="lhd-img"
                  src="{{ section.settings.image_desktop | image_url: width: 2400 }}"
                  alt=""
                  loading="lazy"
                  width="2400"
                  height="1600"
                >
              </picture>
            {%- else -%}
              <div class="lhd-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            <div class="lhd-callout" aria-hidden="true">
              {%- assign active = section.settings.active_icon | default: '1' -%}
              {%- assign active_bubble = blank -%}
              {%- assign active_text = blank -%}

              {%- if active == '1' -%}
                {%- assign active_bubble = section.settings.bubble_icon_1 | default: section.settings.bubble_icon -%}
                {%- assign active_text = section.settings.callout_text_1 -%}
              {%- elsif active == '2' -%}
                {%- assign active_bubble = section.settings.bubble_icon_2 | default: section.settings.bubble_icon -%}
                {%- assign active_text = section.settings.callout_text_2 -%}
              {%- else -%}
                {%- assign active_bubble = section.settings.bubble_icon_3 | default: section.settings.bubble_icon -%}
                {%- assign active_text = section.settings.callout_text_3 -%}
              {%- endif -%}

              <div class="lhd-bubble">
                <span class="lhd-bubble__dot lhd-bubble__dot--1"></span>
                {% comment %} <span class="lhd-bubble__dot lhd-bubble__dot--2"></span>
                <span class="lhd-bubble__dot lhd-bubble__dot--3"></span> {% endcomment %}

                <div class="lhd-bubble__icon">
                  <img
                    class="lhd-bubble__img"
                    {% if active_bubble != blank %}src="{{ active_bubble | image_url: width: 160 }}"{% endif %}
                    alt=""
                    loading="lazy"
                    width="60"
                    height="60"
                    {% if active_bubble == blank %}hidden{% endif %}
                  >
                </div>
              </div>

              <div class="lhd-callout__text">{{ active_text | newline_to_br }}</div>
            </div>
          </div>
        </div>

        <div class="lhd-content">
          <h2 class="lhd-heading">
            <span>WHAT MAKES OUR</span><br>
            <span>HAIR </span><span class="lhd-heading__accent">DIFFERENT</span>
          </h2>

          <div class="lhd-icons" aria-label="Key differences">
            {%- assign bubble_1 = section.settings.bubble_icon_1 | default: section.settings.bubble_icon -%}
            {%- assign bubble_2 = section.settings.bubble_icon_2 | default: section.settings.bubble_icon -%}
            {%- assign bubble_3 = section.settings.bubble_icon_3 | default: section.settings.bubble_icon -%}

            <button
              type="button"
              class="lhd-icon {% if active == '1' %}is-active{% endif %}"
              aria-pressed="{% if active == '1' %}true{% else %}false{% endif %}"
              data-lhd-option="1"
              data-bubble-icon-url="{% if bubble_1 != blank %}{{ bubble_1 | image_url: width: 160 }}{% endif %}"
              data-callout-html="{{ section.settings.callout_text_1 | newline_to_br | escape }}"
            >
              {%- if section.settings.icon_1 != blank -%}
                <img src="{{ section.settings.icon_1 | image_url: width: 120 }}" alt="" loading="lazy" width="56" height="56">
              {%- else -%}
                <svg viewBox="0 0 64 64" aria-hidden="true" focusable="false">
                  <path d="M26 12c10 10 4 17-2 23-7 7-7 13 2 20" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                </svg>
              {%- endif -%}
            </button>

            <button
              type="button"
              class="lhd-icon {% if active == '2' %}is-active{% endif %}"
              aria-pressed="{% if active == '2' %}true{% else %}false{% endif %}"
              data-lhd-option="2"
              data-bubble-icon-url="{% if bubble_2 != blank %}{{ bubble_2 | image_url: width: 160 }}{% endif %}"
              data-callout-html="{{ section.settings.callout_text_2 | newline_to_br | escape }}"
            >
              {%- if section.settings.icon_2 != blank -%}
                <img src="{{ section.settings.icon_2 | image_url: width: 120 }}" alt="" loading="lazy" width="56" height="56">
              {%- else -%}
                <svg viewBox="0 0 64 64" aria-hidden="true" focusable="false">
                  <path d="M24 26c0-6 5-10 10-10h4c6 0 10 4 10 10s-4 10-10 10h-4" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                  <path d="M40 38c0 6-5 10-10 10h-4c-6 0-10-4-10-10s4-10 10-10h4" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                </svg>
              {%- endif -%}
            </button>

            <button
              type="button"
              class="lhd-icon {% if active == '3' %}is-active{% endif %}"
              aria-pressed="{% if active == '3' %}true{% else %}false{% endif %}"
              data-lhd-option="3"
              data-bubble-icon-url="{% if bubble_3 != blank %}{{ bubble_3 | image_url: width: 160 }}{% endif %}"
              data-callout-html="{{ section.settings.callout_text_3 | newline_to_br | escape }}"
            >
              {%- if section.settings.icon_3 != blank -%}
                <img src="{{ section.settings.icon_3 | image_url: width: 120 }}" alt="" loading="lazy" width="56" height="56">
              {%- else -%}
                <svg viewBox="0 0 64 64" aria-hidden="true" focusable="false">
                  <path d="M32 14c2 10-6 10-10 14 8 0 8 8 10 12 2-4 2-12 10-12-4-4-12-4-10-14Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                  <path d="M18 40c6-2 10 2 14 8-2-6 2-10 8-14-6 2-10-2-14-8 2 6-2 10-8 14Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round" opacity=".9"/>
                </svg>
              {%- endif -%}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #LandingHairDifference-{{ section.id }} {
    --lhd-bg: #EEF3F4;
    --lhd-text: #111111;
    --lhd-accent: #74D0E6;
    --lhd-icon-muted: #E6ECEE;
    --lhd-bubble-size: 86px;
    --lhd-bubble-img-w: {{ section.settings.bubble_img_width | default: 60 }}px;
    --lhd-bubble-img-h: {{ section.settings.bubble_img_height | default: 90 }}px;
    --lhd-overlap: 95px; /* like landing-elevated */
    --lhd-overlap-m: 34px;
    --lhd-overlap-top: 280px; /* stronger upward overlap so hanger sticks out */
    --lhd-overlap-top-m: 22px;
    overflow: visible;
  }

  #LandingHairDifference-{{ section.id }} .lhd-surface {
    background: transparent;
    padding: 60px 0 calc(40px + var(--lhd-overlap));
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  /* background layer that stops before the overlap area (same pattern as landing-elevated) */
  #LandingHairDifference-{{ section.id }} .lhd-surface::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: var(--lhd-overlap);
    background: var(--lhd-bg);
    z-index: 0;
  }

  #LandingHairDifference-{{ section.id }} .lhd-surface .page-width {
    position: relative;
    z-index: 1;
  }

  #LandingHairDifference-{{ section.id }} .lhd-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 64px;
    max-width: 1280px;
    margin: 0 auto;
    overflow: visible;
  }

  #LandingHairDifference-{{ section.id }} .lhd-media {
    flex: 0 1 760px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-top: calc(var(--lhd-overlap-top) * -1);
    z-index: 3;
  }

  #LandingHairDifference-{{ section.id }} .lhd-media__inner {
    width: 100%;
    position: relative;
    transform: translateY(var(--lhd-overlap));
  }

  #LandingHairDifference-{{ section.id }} .lhd-media__inner picture {
    width: 100%;
    display: block;
  }

  #LandingHairDifference-{{ section.id }} .lhd-img {
    display: block;
    width: 100%;
    height: 520px;
    object-fit: contain; /* don't crop hanger */
    object-position: left top;
  }

  #LandingHairDifference-{{ section.id }} .lhd-placeholder {
    width: 100%;
    height: 520px;
    background: rgba(0, 0, 0, 0.04);
    display: grid;
    place-items: center;
    border-radius: 8px;
    overflow: hidden;
  }

  #LandingHairDifference-{{ section.id }} .lhd-content {
    flex: 0 1 420px;
    text-align: center;
    width: min(420px, 100%);
  }

  #LandingHairDifference-{{ section.id }} .lhd-heading {
    margin: 0 0 18px;
    font-family: 'Gotham-Regular';
    font-size: 34px;
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: 0px;
    text-transform: uppercase;
    color: var(--lhd-text);
    text-align: right;
  }

  @media (max-width: 768px) {
    #LandingHairDifference-{{ section.id }} .lhd-heading {
      text-align: center;
    }
  }

  #LandingHairDifference-{{ section.id }} .lhd-heading__accent {
    color: var(--lhd-accent);
    font-weight: 700;
  }

  #LandingHairDifference-{{ section.id }} .lhd-icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
  }
 @media (max-width: 768px) {
  #LandingHairDifference-{{ section.id }} .lhd-icons {
    justify-content: center;
  }
 }
  #LandingHairDifference-{{ section.id }} .lhd-icon {
    width: 51px;
    height: 51px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #111111;
    background: #DCF8F9;
    border: 0;
    padding: 0;
    appearance: none;
    cursor: pointer;
  }

  #LandingHairDifference-{{ section.id }} .lhd-icon.is-active {
    /* background: #111111; */
    color: var(--lhd-accent);

    outline: 6px solid black;
  }

  #LandingHairDifference-{{ section.id }} .lhd-icon:focus-visible {
    outline: 3px solid rgba(0, 0, 0, 0.6);
    outline-offset: 3px;
  }

  #LandingHairDifference-{{ section.id }} .lhd-icon img {
    object-fit: contain;
    display: block;
    filter: none;
  }

  #LandingHairDifference-{{ section.id }} .lhd-icon svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  #LandingHairDifference-{{ section.id }} .lhd-callout {
    position: absolute;
    left: 41%;
    top: 54%;
    /* Use bubble-based translate so text length doesn't move the bubble */
    transform: translate(
      calc(var(--lhd-bubble-size) * -0.58),
      calc(var(--lhd-bubble-size) * -0.79)
    );
    display: flex;
    align-items: center;
    gap: 14px;
    pointer-events: none;
    user-select: none;
  }

  #LandingHairDifference-{{ section.id }} .lhd-bubble {
    width: var(--lhd-bubble-size);
    height: var(--lhd-bubble-size);
    border-radius: 999px;
    background: #111111;
    position: relative;
    display: grid;
    place-items: center;
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.18);
    border: 1px solid #75D1E0;
  }

  #LandingHairDifference-{{ section.id }} .lhd-bubble__icon img {
    width: var(--lhd-bubble-img-w);
    height: var(--lhd-bubble-img-h);
    display: block;
    object-fit: contain;
  }

  #LandingHairDifference-{{ section.id }} .lhd-bubble__dot {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--lhd-accent);
    opacity: 0.95;
  }

  #LandingHairDifference-{{ section.id }} .lhd-bubble__dot--1 { left: -8px; top: 38px; }
  #LandingHairDifference-{{ section.id }} .lhd-bubble__dot--2 { left: -2px; top: 32px; width: 5px; height: 5px; opacity: 0.8; }
  #LandingHairDifference-{{ section.id }} .lhd-bubble__dot--3 { left: -2px; top: 44px; width: 5px; height: 5px; opacity: 0.8; }

  #LandingHairDifference-{{ section.id }} .lhd-callout__text {
    font-family: 'Gotham-Regular';
    font-size: 16px;
    font-weight: 400;
    line-height: 1.15;
    color: #111111;
    text-align: left;
    white-space: nowrap;
  }

  /* Mobile: matches your second screenshot (title/icons first, image second) */
  @media (max-width: 768px) {
    #LandingHairDifference-{{ section.id }} {
      --lhd-bubble-size: 92px;
    }

    #LandingHairDifference-{{ section.id }} .lhd-surface {
      padding: 34px 0 calc(18px + var(--lhd-overlap-m));
    }

    #LandingHairDifference-{{ section.id }} .lhd-surface .page-width {
      padding-left: 0;
      padding-right: 0;
    }

    #LandingHairDifference-{{ section.id }} .lhd-surface::before {
      bottom: var(--lhd-overlap-m);
    }

    #LandingHairDifference-{{ section.id }} .lhd-grid {
      flex-direction: column;
      gap: 18px;
    }

    #LandingHairDifference-{{ section.id }} .lhd-content {
      order: 1;
      flex: 0 1 100%;
      justify-self: center;
      width: 100%;
    }

    #LandingHairDifference-{{ section.id }} .lhd-media {
      order: 2;
      justify-content: center;
      margin-top: calc(var(--lhd-overlap-top-m) * -1);
      flex: 0 0 auto;
      width: 100%;
    }

    #LandingHairDifference-{{ section.id }} .lhd-img {
      height: 500px;
      width: 300px;
      object-fit: contain;
      object-position: center center;
    }

    #LandingHairDifference-{{ section.id }} .lhd-media__inner {
      transform: translateY(var(--lhd-overlap-m));
      width: min(520px, 100%);
      margin: 0 auto;
    }

    #LandingHairDifference-{{ section.id }} .lhd-heading {
      font-size: 30px;
      line-height: 1.12;
      margin-bottom: 16px;
    }

    #LandingHairDifference-{{ section.id }} .lhd-callout {
      left: auto;
      bottom: auto;
      right: 0px;
      top: 40%;
      transform: none;
      gap: 12px;
      align-items: center;
    }

    #LandingHairDifference-{{ section.id }} .lhd-bubble { }

    #LandingHairDifference-{{ section.id }} .lhd-callout__text {
      font-size: 14px;
      white-space: normal;
      width: 120px;
      margin-top: 70px;
    }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('LandingHairDifference-{{ section.id }}');
    if (!root) return;

    const icons = Array.from(root.querySelectorAll('.lhd-icon[data-lhd-option]'));
    const calloutText = root.querySelector('.lhd-callout__text');
    const bubbleImg = root.querySelector('.lhd-bubble__img');

    if (!icons.length || !calloutText || !bubbleImg) return;

    const setBubble = (url) => {
      const hasUrl = typeof url === 'string' && url.trim().length > 0;
      if (hasUrl) {
        bubbleImg.src = url;
        bubbleImg.hidden = false;
      } else {
        bubbleImg.removeAttribute('src');
        bubbleImg.hidden = true;
      }
    };

    const activate = (btn) => {
      icons.forEach((el) => {
        el.classList.remove('is-active');
        el.setAttribute('aria-pressed', 'false');
      });

      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');

      setBubble(btn.dataset.bubbleIconUrl);
      if (btn.dataset.calloutHtml) calloutText.innerHTML = btn.dataset.calloutHtml;
    };

    icons.forEach((btn) => {
      btn.addEventListener('click', () => activate(btn));
      btn.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activate(btn);
        }
      });
    });

    const preActive = icons.find((el) => el.classList.contains('is-active')) || icons[0];
    if (preActive) activate(preActive);
  })();
</script>

