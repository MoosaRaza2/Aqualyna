{{ 'lp-adcrunch-new-verified-reviews.css' | asset_url | stylesheet_tag }}

<section class="lp-trust-bar" id="lp-trust-bar-{{ section.id }}" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  <div class="lp-trust-bar__container">
    <div class="lp-trust-bar__items">
      {% for block in section.blocks %}
        <div class="lp-trust-bar__item" {{ block.shopify_attributes }}>
          <span class="lp-trust-bar__icon">{{ block.settings.icon }}</span>
          <span class="lp-trust-bar__text">{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#5BBFC3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji or Symbol)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "★★★★★",
            "text": "142 verified reviews"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "✓",
            "text": "100% Remy Human Hair"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "⚡",
            "text": "Ships next business day"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "🔄",
            "text": "30-day hassle-free returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}