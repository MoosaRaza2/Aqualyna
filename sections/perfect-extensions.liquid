{% comment %}
  Section: Perfect Extensions Explainer
  Horizontal accordion on desktop, vertical stack on mobile
  Panels: Systems | Length & Weight
{% endcomment %}

<section class="pe-section" id="perfect-extensions-{{ section.id }}">
  <div class="pe-wrapper">

    {%- comment -%} Left static heading {%- endcomment -%}
    <div class="pe-heading">
      <h2 class="pe-heading__title">
        {{ section.settings.heading_line1 | default: 'YOUR PERFECT' }}<br>
        {{ section.settings.heading_line2 | default: 'EXTENSIONS,' }}<br>
        <span class="pe-heading__accent">{{ section.settings.heading_accent | default: 'EXPLAINED' }}</span>
      </h2>
    </div>

    {%- comment -%} Accordion panels {%- endcomment -%}
    <div class="pe-accordion" role="tablist">

      {%- comment -%} Panel 1: Systems {%- endcomment -%}
      <div class="pe-panel pe-panel--systems is-active" data-panel="systems" role="tab" aria-selected="true" aria-expanded="true">
        <button class="pe-panel__trigger" aria-label="Open Systems panel">
          <span class="pe-trigger-icon pe-trigger-icon--closed" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="19" height="22" viewBox="0 0 19 22" fill="none">
              <path d="M18.75 10.8253L8.87767e-07 21.6506L1.83415e-06 -8.19588e-07L18.75 10.8253Z" fill="#75D1E0"/>
            </svg>
          </span>
          <span class="pe-trigger-icon pe-trigger-icon--open" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="19" height="22" viewBox="0 0 19 22" fill="none">
              <path d="M1.44118e-07 10.8253L18.1282 -1.68376e-06L18.1282 21.6506L1.44118e-07 10.8253Z" fill="#75D1E0"/>
            </svg>
          </span>
        </button>

        <div class="pe-panel__content">
          {%- assign systems_desktop_image = section.settings.systems_image_desktop -%}
          {%- if systems_desktop_image == blank -%}{%- assign systems_desktop_image = section.settings.systems_image -%}{%- endif -%}
          {%- assign systems_mobile_image = section.settings.systems_image_mobile -%}
          {%- if systems_mobile_image == blank -%}{%- assign systems_mobile_image = systems_desktop_image -%}{%- endif -%}

          <div class="pe-panel__card">
            <div class="pe-panel__body pe-panel__body--card">
              <h3 class="pe-panel__title pe-panel__title--card">{{ section.settings.systems_title | default: 'SYSTEMS' }}</h3>

              <ul class="pe-icon-list" role="list">
                {%- assign rendered_any = false -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'system_item' -%}
                    {%- assign rendered_any = true -%}
                    <li class="pe-icon-list__item" {{ block.shopify_attributes }}>
                      <span class="pe-icon-list__icon" aria-hidden="true">
                        {%- if block.settings.icon != blank -%}
                          <img
                            src="{{ block.settings.icon | image_url: width: 160 }}"
                            alt="{{ block.settings.icon.alt | escape }}"
                            loading="lazy"
                            width="80"
                            height="80"
                          >
                        {%- endif -%}
                      </span>
                      <span class="pe-icon-list__text">{{ block.settings.name }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}

                {%- unless rendered_any -%}
                  <li class="pe-icon-list__item">
                    <span class="pe-icon-list__icon" aria-hidden="true"></span>
                    <span class="pe-icon-list__text">Ultra Narrow Clip In</span>
                  </li>
                  <li class="pe-icon-list__item">
                    <span class="pe-icon-list__icon" aria-hidden="true"></span>
                    <span class="pe-icon-list__text">Aura</span>
                  </li>
                  <li class="pe-icon-list__item">
                    <span class="pe-icon-list__icon" aria-hidden="true"></span>
                    <span class="pe-icon-list__text">Ponytail</span>
                  </li>
                {%- endunless -%}
              </ul>
            </div>

            <div class="pe-panel__hero">
              {%- if systems_desktop_image != blank -%}
                <picture class="pe-panel__picture">
                  {%- if systems_mobile_image != blank -%}
                    <source media="(max-width: 768px)" srcset="{{ systems_mobile_image | image_url: width: 900 }}">
                  {%- endif -%}
                  <img
                    src="{{ systems_desktop_image | image_url: width: 1200 }}"
                    alt="{{ systems_desktop_image.alt | escape }}"
                    class="pe-panel__hero-image"
                    loading="lazy"
                    width="1200"
                    height="900"
                  >
                </picture>
              {%- else -%}
                <div class="pe-panel__bg-placeholder pe-panel__bg-placeholder--dark"></div>
              {%- endif -%}
            </div>
          </div>
        </div>

        <div class="pe-panel__tab-label">
          <span>{{ section.settings.systems_title | default: 'SYSTEMS' }}</span>
        </div>
      </div>

      {%- comment -%} Panel 2: Length & Weight {%- endcomment -%}
      <div class="pe-panel pe-panel--lw" data-panel="lw" role="tab" aria-selected="false" aria-expanded="false">
        <button class="pe-panel__trigger" aria-label="Open Length & Weight panel">
          <span class="pe-trigger-icon pe-trigger-icon--closed" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="19" height="22" viewBox="0 0 19 22" fill="none">
              <path d="M18.75 10.8253L8.87767e-07 21.6506L1.83415e-06 -8.19588e-07L18.75 10.8253Z" fill="#75D1E0"/>
            </svg>
          </span>
          <span class="pe-trigger-icon pe-trigger-icon--open" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="19" height="22" viewBox="0 0 19 22" fill="none">
              <path d="M1.44118e-07 10.8253L18.1282 -1.68376e-06L18.1282 21.6506L1.44118e-07 10.8253Z" fill="#75D1E0"/>
            </svg>
          </span>
        </button>

        <div class="pe-panel__content">
          {%- assign lw_desktop_image = section.settings.lw_image_desktop -%}
          {%- if lw_desktop_image == blank -%}{%- assign lw_desktop_image = section.settings.lw_image -%}{%- endif -%}
          {%- assign lw_mobile_image = section.settings.lw_image_mobile -%}
          {%- if lw_mobile_image == blank -%}{%- assign lw_mobile_image = lw_desktop_image -%}{%- endif -%}

          {%- if section.settings.lw_content_type == 'table' -%}
            {%- if lw_desktop_image != blank -%}
              <img
                src="{{ lw_desktop_image | image_url: width: 900 }}"
                alt="{{ lw_desktop_image.alt | escape }}"
                class="pe-panel__bg-image"
                loading="lazy"
                width="900"
                height="600"
              >
            {%- else -%}
              <div class="pe-panel__bg-placeholder pe-panel__bg-placeholder--hair"></div>
            {%- endif -%}

            <div class="pe-panel__overlay pe-panel__overlay--dark"></div>

            <div class="pe-panel__body pe-panel__body--lw">
              <h3 class="pe-panel__title pe-panel__title--lw">{{ section.settings.lw_title | default: 'LENGTH & WEIGHT' }}</h3>

              {%- for block in section.blocks -%}
                {%- if block.type == 'lw_group' -%}
                  <div class="pe-lw-group" {{ block.shopify_attributes }}>
                    <h4 class="pe-lw-group__name">{{ block.settings.group_name }}</h4>
                    <div class="pe-lw-rows">
                      {%- if block.settings.row1_size != blank -%}
                        <div class="pe-lw-row">
                          <div class="pe-lw-badge">{{ block.settings.row1_size }}</div>
                          <span class="pe-lw-weight">{{ block.settings.row1_weight }}</span>
                          {%- if block.settings.row1b_size != blank -%}
                            <div class="pe-lw-badge">{{ block.settings.row1b_size }}</div>
                            <span class="pe-lw-weight">{{ block.settings.row1b_weight }}</span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      {%- if block.settings.row2_size != blank -%}
                        <div class="pe-lw-row">
                          <div class="pe-lw-badge">{{ block.settings.row2_size }}</div>
                          <span class="pe-lw-weight">{{ block.settings.row2_weight }}</span>
                          {%- if block.settings.row2b_size != blank -%}
                            <div class="pe-lw-badge">{{ block.settings.row2b_size }}</div>
                            <span class="pe-lw-weight">{{ block.settings.row2b_weight }}</span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      {%- if block.settings.row3_size != blank -%}
                        <div class="pe-lw-row">
                          <div class="pe-lw-badge">{{ block.settings.row3_size }}</div>
                          <span class="pe-lw-weight">{{ block.settings.row3_weight }}</span>
                          {%- if block.settings.row3b_size != blank -%}
                            <div class="pe-lw-badge">{{ block.settings.row3b_size }}</div>
                            <span class="pe-lw-weight">{{ block.settings.row3b_weight }}</span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="pe-panel__card">
              <div class="pe-panel__body pe-panel__body--card">
                <h3 class="pe-panel__title pe-panel__title--card">{{ section.settings.lw_title | default: 'LENGTH & WEIGHT' }}</h3>

                <ul class="pe-icon-list" role="list">
                  {%- assign rendered_any = false -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'lw_item' -%}
                      {%- assign rendered_any = true -%}
                      <li class="pe-icon-list__item" {{ block.shopify_attributes }}>
                        <span class="pe-icon-list__icon" aria-hidden="true">
                          {%- if block.settings.icon != blank -%}
                            <img
                              src="{{ block.settings.icon | image_url: width: 160 }}"
                              alt="{{ block.settings.icon.alt | escape }}"
                              loading="lazy"
                              width="80"
                              height="80"
                            >
                          {%- endif -%}
                        </span>
                        <span class="pe-icon-list__text">{{ block.settings.name }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}

                  {%- unless rendered_any -%}
                    {%- comment -%} Fallback: reuse Systems items if present {%- endcomment -%}
                    {%- assign rendered_systems = false -%}
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'system_item' -%}
                        {%- assign rendered_systems = true -%}
                        <li class="pe-icon-list__item">
                          <span class="pe-icon-list__icon" aria-hidden="true">
                            {%- if block.settings.icon != blank -%}
                              <img
                                src="{{ block.settings.icon | image_url: width: 160 }}"
                                alt="{{ block.settings.icon.alt | escape }}"
                                loading="lazy"
                                width="80"
                                height="80"
                              >
                            {%- endif -%}
                          </span>
                          <span class="pe-icon-list__text">{{ block.settings.name }}</span>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}

                    {%- unless rendered_systems -%}
                      <li class="pe-icon-list__item">
                        <span class="pe-icon-list__icon" aria-hidden="true"></span>
                        <span class="pe-icon-list__text">Ultra Narrow Clip In</span>
                      </li>
                      <li class="pe-icon-list__item">
                        <span class="pe-icon-list__icon" aria-hidden="true"></span>
                        <span class="pe-icon-list__text">Aura</span>
                      </li>
                      <li class="pe-icon-list__item">
                        <span class="pe-icon-list__icon" aria-hidden="true"></span>
                        <span class="pe-icon-list__text">Ponytail</span>
                      </li>
                    {%- endunless -%}
                  {%- endunless -%}
                </ul>
              </div>

              <div class="pe-panel__hero">
                {%- if lw_desktop_image != blank -%}
                  <picture class="pe-panel__picture">
                    {%- if lw_mobile_image != blank -%}
                      <source media="(max-width: 768px)" srcset="{{ lw_mobile_image | image_url: width: 900 }}">
                    {%- endif -%}
                    <img
                      src="{{ lw_desktop_image | image_url: width: 1200 }}"
                      alt="{{ lw_desktop_image.alt | escape }}"
                      class="pe-panel__hero-image"
                      loading="lazy"
                      width="1200"
                      height="900"
                    >
                  </picture>
                {%- else -%}
                  <div class="pe-panel__bg-placeholder pe-panel__bg-placeholder--hair"></div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>

        <div class="pe-panel__tab-label">
          <span>{{ section.settings.lw_title | default: 'LENGTH & WEIGHT' }}</span>
        </div>
      </div>

    </div><!-- /.pe-accordion -->
  </div><!-- /.pe-wrapper -->
</section>

<style>
  /* ============================================================
     PERFECT EXTENSIONS — Section Styles
  ============================================================ */
  #perfect-extensions-{{ section.id }} {
    --teal: #6ecfcf;
    --teal-light: #DCF8F9;
    --teal-dark: #4ab8b8;
    --dark: #1a1a1a;
    --text-dark: #1c2b35;
    --font-heading: 'Helvetica Neue', Arial, sans-serif;
    --panel-collapsed: 164px;
    --panel-expanded: 580px;
    --section-height: 480px;
    --pe-radius: 25px;
    font-family: var(--font-heading);
  }

  .pe-section {
    width: 100%;
    overflow: hidden;
    background: #fff;
    padding: 60px 40px 140px 40px;
    box-sizing: border-box;
  }

  .pe-wrapper {
    display: flex;
    align-items: center;
    gap: 0;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ---- Heading ---- */
  .pe-heading {
    flex: 0 0 auto;
    width: 500px;
  }

  .pe-heading__title {
    color: #000;
    font-family: 'Gotham-Regular';
    font-size: 40px;
    font-style: normal;
    font-weight: 300;
    line-height: 58px; /* 145% */
    text-transform: uppercase;
    margin-left: 88px;
  }

  @media (max-width: 768px) {
    .pe-heading__title {
     text-align: center;
     font-size: 24px;
     line-height: 28px;
     margin-left: 0px;
    }
  }

  .pe-heading__accent {
    color: var(--teal);
    font-weight: 700;
  }

  /* ---- Accordion ---- */
  .pe-accordion {
    display: flex;
    flex: 1;
    height: 510px;
    gap: 0;
    overflow: hidden;
    border-radius: var(--pe-radius);
    justify-content: center;
    box-sizing: border-box;
    padding: 0;
  }

  /*
    Center the ACTIVE panel in the available accordion area.
    We offset the flex group by exactly one collapsed tab width,
    depending on which side the collapsed tab is sitting on.

    This offset is only applied on wider layouts to avoid clipping
    on smaller desktops where the accordion width can get tight.
  */
  @media (min-width: 1024px) {
    .pe-accordion.pe-accordion--systems-active {
      /* padding-left: var(--panel-collapsed); */
      padding-right: 0;
    }

    .pe-accordion.pe-accordion--lw-active {
      /* padding-right: var(--panel-collapsed); */
      padding-left: 0;
    }
  }

  /* ---- Panel ---- */
  .pe-panel {
    position: relative;
    flex: 0 0 var(--panel-collapsed);
    height: 100%;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.55s cubic-bezier(0.77, 0, 0.175, 1);
    border-radius: var(--pe-radius);
    background: var(--teal-light);
  }

  .pe-panel.is-active {
    flex: 0 0 var(--panel-expanded);
    cursor: default;
  }

  /* Collapsed panels: solid background (no image) */
  .pe-panel__content {
    opacity: 1;
    transition: opacity 0.25s ease;
  }

  .pe-panel:not(.is-active) .pe-panel__content {
    opacity: 0;
  }

  .pe-panel:not(.is-active) .pe-panel__tab-label span {
    color: #40696F;
  }

  /* --- collapsed tab label (rotated) --- */
  .pe-panel__tab-label {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(var(--panel-collapsed) - 16px);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 5;
    text-align: center;
    color: #40696F;
    font-family: 'Gotham-Medium';
    font-size: 25px;
    font-style: normal;
    font-weight: 350;
    line-height: 34px; /* 136% */
    text-transform: uppercase;
  }

  .pe-panel.is-active .pe-panel__tab-label {
    opacity: 0;
    pointer-events: none;
  }

  .pe-panel__tab-label span {
    display: block;
    writing-mode: horizontal-tb;
    transform: none;
    font-size: 25px;
    font-weight: 400;
    /* letter-spacing: 0.15em; */
    text-transform: uppercase;
    color: var(--teal);
    line-height: 1.15;
    white-space: normal;
    font-family: 'Gotham-Regular';
  }

  /* --- trigger button (arrow) --- */
  .pe-panel__trigger {
    position: absolute;
    top: 16px;
    right: 16px;
    left: auto;
    z-index: 10;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    line-height: 1;
    display: block;
  }

  .pe-panel__trigger svg {
    display: block;
    width: 19px;
    height: 22px;
  }

  /* Closed vs open icon toggle */
  .pe-trigger-icon--open {
    display: none;
  }

  .pe-panel.is-active .pe-trigger-icon--closed {
    display: none;
  }

  .pe-panel.is-active .pe-trigger-icon--open {
    display: inline-flex;
  }

  /* --- Background image/placeholder --- */
  .pe-panel__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .pe-panel__bg-placeholder {
    position: absolute;
    inset: 0;
  }

  .pe-panel__bg-placeholder--dark {
    background: linear-gradient(135deg, #2c3e35 0%, #1a2a22 100%);
  }

  .pe-panel__bg-placeholder--hair {
    background: linear-gradient(135deg, #3d3028 0%, #1a1410 60%, #2a2018 100%);
  }

  /* --- Overlay --- */
  .pe-panel__overlay {
    /* position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.15) 100%);
    z-index: 1; */
  }

  .pe-panel__overlay--dark {
    background: linear-gradient(to bottom right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 100%);
  }

  /* --- Panel Content (full expanded area) --- */
  .pe-panel__content {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* --- Card layout (matches provided design) --- */
  .pe-panel__card {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 52%);
    background: radial-gradient(140% 120% at 0% 0%, #ffffff 0%, #F4FBFC 55%, #EAF7F9 100%);
    border: 1px solid rgba(64, 105, 111, 0.18);
    border-radius: var(--pe-radius);
    overflow: hidden;
  }

  .pe-panel__hero {
    position: relative;
    overflow: hidden;
  }

  .pe-panel__picture,
  .pe-panel__picture img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .pe-panel__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
  }

  /* --- Panel Body (text layer) --- */
  .pe-panel__body {
    position: absolute;
    inset: 0;
    z-index: 2;
    padding: 32px 30px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    opacity: 0;
    /* transition: opacity 0.35s ease 0.15s; */
  }

  .pe-panel.is-active .pe-panel__body {
    opacity: 1;
  }

  .pe-panel__body--card {
    position: relative;
    inset: auto;
    width: 100%;
    height: 100%;
    padding: 36px 34px;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 22px;
  }

  /* ---- Systems Panel ---- */
  .pe-panel--systems {
    background: var(--teal-light);
  }

  /* Systems: collapsed shows teal bg + label */
  .pe-panel__title {
    color: #FFF;
    font-family: 'Gotham-Medium';
    font-size: 25px;
    font-style: normal;
    font-weight: 350;
    line-height: 34px; /* 136% */
    text-transform: uppercase;
    margin: 0 0 16px 0;
  }

  .pe-systems-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pe-systems-list__item {
    color: #FFF;
    font-family: 'Gotham-Regular';
    font-size: 16px;
    font-style: normal;
    font-weight: 325;
    line-height: 24px; /* 150% */
  }

  /* --- Icon list (card layout) --- */
  .pe-panel__title--card {
    color: #111;
    font-family: 'Gotham-Medium';
    font-size: 22px;
    font-style: normal;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  .pe-icon-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .pe-icon-list__item {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .pe-icon-list__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid #75D1E0;
    background: #fff;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .pe-icon-list__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pe-icon-list__text {
    color: #40696F;
    font-family: 'Gotham-Regular';
    font-size: 16px;
    font-style: normal;
    font-weight: 350;
    line-height: 1.3;
  }

  /* ---- Length & Weight Panel ---- */
  .pe-panel--lw {
    background: var(--teal-light);
    margin-left: 6px;
  }

  .pe-panel__title--lw {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 25px 0;
  }

  .pe-panel__body--lw {
    justify-content: flex-start;
    padding-top: 30px;
    overflow-y: auto;
    gap: 0;
    padding-left: 70px;
  }

  .pe-lw-group {
    margin-bottom: 18px;
  }

  .pe-lw-group__name {
    color: #FFF;
    font-family: 'Gotham-Regular';
    font-size: 13px;
    font-style: normal;
    font-weight: 700;
    line-height: 22px; /* 169.231% */
    margin-bottom: 8px;
  }

  .pe-lw-rows {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pe-lw-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: nowrap;
  }

