  /* ============================================================
     MOBILE — vertical stack
  ============================================================ */
  @media (max-width: 768px) {
    #perfect-extensions-{{ section.id }} {
      --pe-radius: 12px;
    }

    .pe-section {
      padding: 30px 20px 70px 20px;
    }

    .pe-wrapper {
      flex-direction: column;
      gap: 30px;
    }

    .pe-heading {
      width: 100%;
      padding-right: 0;
      text-align: left;
    }

    .pe-accordion {
      flex-direction: column;
      height: auto;
      width: 100%;
      gap: 12px;
      border-radius: 12px;
      padding: 0;
      justify-content: flex-start;
    }

    .pe-panel {
      flex: none !important;
      width: 100%;
      height: 72px;
      border-radius: 12px;
      overflow: hidden;
      transition: height 0.45s cubic-bezier(0.77, 0, 0.175, 1);
    }

    .pe-panel.is-active {
      height: 520px;
    }

    .pe-panel__tab-label {
      bottom: auto;
      top: 0;
      width: 100%;
      height: 72px;
      justify-content: flex-start;
      padding-left: 20px;
    }

    .pe-panel.is-active .pe-panel__tab-label {
      opacity: 0;
    }

    .pe-panel__tab-label span {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: 1.3rem;
    }

    .pe-panel__trigger {
      top: 16px;
      right: 16px;
      left: auto;
    }

    /* Mobile: rotate icons so they behave like down/up arrows */
    .pe-panel__trigger svg {
      transform: rotate(90deg);
      transform-origin: 50% 50%;
    }

    .pe-panel--lw {
      margin-left: 0;
    }

    .pe-panel__body {
      padding: 30px;
    }

    .pe-panel__body--lw {
      padding-top: 40px;
    }

    .pe-panel__card {
      grid-template-columns: minmax(0, 1fr) minmax(0, 46%);
    }

    .pe-panel__body--card {
      padding: 36px 26px 26px 26px;
      gap: 26px;
    }

    .pe-panel__title--card {
      font-size: 18px;
    }

    .pe-icon-list {
      gap: 30px;
