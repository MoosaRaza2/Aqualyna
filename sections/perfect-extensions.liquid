    .pe-icon-list__icon {
      width: 74px;
      height: 74px;
    }

    .pe-icon-list__text {
      font-size: 34px;
      line-height: 1.15;
    }

    .pe-lw-badge {
      width: 32px;
      height: 32px;
      font-size: 0.58rem;
    }
  }

  @media (max-width: 768px) {
    .pe-panel__trigger svg {
    display: block;
    width: 14px;
    height: 20px;
}
  }

  /* Collapsed panels use the same light background */


</style>

<script>
  (function() {
    var sectionId = 'perfect-extensions-{{ section.id }}';
    var section = document.getElementById(sectionId);
    if (!section) return;

    var accordion = section.querySelector('.pe-accordion');
    var panels = section.querySelectorAll('.pe-panel');

    function syncAccordionOffset(activePanel) {
      if (!accordion || !activePanel) return;
      accordion.classList.remove('pe-accordion--systems-active', 'pe-accordion--lw-active');
      if (activePanel.classList.contains('pe-panel--systems')) {
        accordion.classList.add('pe-accordion--systems-active');
      } else if (activePanel.classList.contains('pe-panel--lw')) {
        accordion.classList.add('pe-accordion--lw-active');
      }
    }

    function openPanel(targetPanel) {
      panels.forEach(function(p) {
        p.classList.remove('is-active');
        p.setAttribute('aria-selected', 'false');
        p.setAttribute('aria-expanded', 'false');
      });
      targetPanel.classList.add('is-active');
      targetPanel.setAttribute('aria-selected', 'true');
      targetPanel.setAttribute('aria-expanded', 'true');
      syncAccordionOffset(targetPanel);
    }

    // Ensure initial centering matches the initial active panel
    var initialActive = section.querySelector('.pe-panel.is-active');
    if (initialActive) syncAccordionOffset(initialActive);

    panels.forEach(function(panel) {
      // Click on collapsed panel to open
      panel.addEventListener('click', function(e) {
        if (!panel.classList.contains('is-active')) {
          openPanel(panel);
        }
      });

      // Trigger button: close current, open the other
      var trigger = panel.querySelector('.pe-panel__trigger');
      if (trigger) {
        trigger.addEventListener('click', function(e) {
          e.stopPropagation();
          // If the panel is closed, open it. If it's open, switch to the other.
          if (!panel.classList.contains('is-active')) {
            openPanel(panel);
            return;
          }
          panels.forEach(function(p) {
            if (p !== panel) openPanel(p);
          });
        });
      }
    });
  })();
</script>

