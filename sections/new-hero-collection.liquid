{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign bg_color = section.settings.background-color
  assign text_color = section.settings.text-color
  assign text_alignment = section.settings.text-alignment
  assign desktop_image = section.settings.desktop-image
  assign mobile_image = section.settings.mobile-image
  assign image_position = section.settings.image-position
  assign desktop_height = section.settings.desktop-height
  assign mobile_height = section.settings.mobile-height
  assign button_text = section.settings.button-text
  assign button_url = section.settings.button-url
-%}

<style>
  .new-hero-collection--{{ section.id }} {
    --hero-bg: {{ bg_color }};
    --hero-text: {{ text_color }};
    --hero-desktop-height: {{ desktop_height }}px;
    --hero-mobile-height: {{ mobile_height }}px;
  }

  .new-hero-collection[data-section-id] {
    padding: 0;
    margin: 0;
  }

  [data-toggle-menu="browse-filter"] {
    display: none !important;
  }

  .filter--category:first-of-type {
    display: none !important;
  }

  .new-hero-collection {
    display: flex;
    align-items: stretch;
    width: 100%;
    min-height: var(--hero-desktop-height);
    background-color: var(--hero-bg);
    color: var(--hero-text);
    overflow: hidden;
  }

  .new-hero-collection[data-image-position="right"] {
    flex-direction: row;
  }

  .new-hero-collection[data-image-position="left"] {
    flex-direction: row-reverse;
  }

  .new-hero-collection__image-wrapper {
    flex: 1 1 50%;
    position: relative;
    overflow: hidden;
    min-height: var(--hero-desktop-height);
  }

  .new-hero-collection__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .new-hero-collection__image-wrapper .new-hero-collection__image--desktop {
    display: block;
  }

  .new-hero-collection__image-wrapper .new-hero-collection__image--mobile {
    display: none;
  }

  .new-hero-collection__content {
    flex: 1 1 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 80px;
    text-align: {{ text_alignment }};
  }

  .new-hero-collection__heading {
    font-family: inherit;
    font-weight: 700;
    font-size: 32px;
    line-height: 1.25;
    margin: 0 0 20px;
    letter-spacing: 0.02em;
  }

  .new-hero-collection__subheading {
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
  }

  .new-hero-collection__button {
    display: inline-block;
    margin-top: 30px;
    padding: 14px 36px;
    background-color: var(--hero-text);
    color: var(--hero-bg);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .new-hero-collection__button:hover {
    opacity: 0.8;
  }

  @media only screen and (max-width: 767px) {
    .new-hero-collection {
      flex-direction: column !important;
      min-height: auto;
    }

    .new-hero-collection__image-wrapper {
      flex: none;
      width: 100%;
      min-height: var(--hero-mobile-height);
    }

    .new-hero-collection__image-wrapper .new-hero-collection__image--desktop {
      display: none;
    }

    .new-hero-collection__image-wrapper .new-hero-collection__image--mobile {
      display: block;
    }

    .new-hero-collection__content {
      flex: none;
      width: 100%;
      padding: 40px 24px;
      text-align: center;
    }

    .new-hero-collection__heading {
      font-size: 24px;
    }

    .new-hero-collection__subheading {
      font-size: 14px;
    }
  }
</style>

<div
  class="new-hero-collection new-hero-collection--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-image-position="{{ image_position }}"
>
  <div class="new-hero-collection__image-wrapper">
    {%- if desktop_image -%}
      <img
        class="new-hero-collection__image--desktop"
        src="{{ desktop_image | image_url: width: 1600 }}"
        srcset="
          {{ desktop_image | image_url: width: 800 }} 800w,
          {{ desktop_image | image_url: width: 1200 }} 1200w,
          {{ desktop_image | image_url: width: 1600 }} 1600w,
          {{ desktop_image | image_url: width: 2000 }} 2000w
        "
        sizes="50vw"
        alt="{{ desktop_image.alt | default: heading | escape }}"
        loading="eager"
        width="{{ desktop_image.width }}"
        height="{{ desktop_image.height }}"
      >
    {%- else -%}
      <div class="new-hero-collection__image--desktop" style="width:100%;height:100%;background:#ddd;"></div>
    {%- endif -%}

    {%- if mobile_image -%}
      <img
        class="new-hero-collection__image--mobile"
        src="{{ mobile_image | image_url: width: 800 }}"
        srcset="
          {{ mobile_image | image_url: width: 400 }} 400w,
          {{ mobile_image | image_url: width: 600 }} 600w,
          {{ mobile_image | image_url: width: 800 }} 800w
        "
        sizes="100vw"
        alt="{{ mobile_image.alt | default: heading | escape }}"
        loading="eager"
        width="{{ mobile_image.width }}"
        height="{{ mobile_image.height }}"
      >
    {%- elsif desktop_image -%}
      <img
        class="new-hero-collection__image--mobile"
        src="{{ desktop_image | image_url: width: 800 }}"
        srcset="
          {{ desktop_image | image_url: width: 400 }} 400w,
          {{ desktop_image | image_url: width: 600 }} 600w,
          {{ desktop_image | image_url: width: 800 }} 800w
        "
        sizes="100vw"
        alt="{{ desktop_image.alt | default: heading | escape }}"
        loading="eager"
        width="{{ desktop_image.width }}"
        height="{{ desktop_image.height }}"
      >
    {%- else -%}
      <div class="new-hero-collection__image--mobile" style="width:100%;height:100%;background:#ddd;"></div>
    {%- endif -%}
  </div>

  <div class="new-hero-collection__content">
    {%- if heading != blank -%}
      <h2 class="new-hero-collection__heading">{{ heading }}</h2>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="new-hero-collection__subheading">{{ subheading }}</p>
    {%- endif -%}

    {%- if button_text != blank and button_url != blank -%}
      <div>
        <a class="new-hero-collection__button" href="{{ button_url }}">{{ button_text }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "New hero collection",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "id": "desktop-image",
      "label": "Desktop image",
      "type": "image_picker"
    },
    {
      "id": "mobile-image",
      "label": "Mobile image (optional)",
      "type": "image_picker",
      "info": "If not set, desktop image will be used on mobile"
    },
    {
      "id": "image-position",
      "label": "Image position",
      "type": "select",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "info": "On mobile the image always stacks on top"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "id": "heading",
      "label": "Heading",
      "type": "text",
      "default": "Instant Gorgeous Celeb-Worthy Hair With Ultra Narrow Clip In Hair Extensions"
    },
    {
      "id": "subheading",
      "label": "Subheading",
      "type": "text",
      "default": "Lengths Available: 18in, 20in, 22in, 24in, 26in"
    },
    {
      "id": "text-alignment",
      "label": "Text alignment",
      "type": "select",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "id": "button-text",
      "label": "Button text",
      "type": "text"
    },
    {
      "id": "button-url",
      "label": "Button link",
      "type": "url"
    },
    {
      "type": "header",
      "content": "Colors and sizing"
    },
    {
      "id": "background-color",
      "label": "Background color",
      "type": "color",
      "default": "#87CEEB"
    },
    {
      "id": "text-color",
      "label": "Text color",
      "type": "color",
      "default": "#000000"
    },
    {
      "id": "desktop-height",
      "label": "Desktop section height (px)",
      "type": "range",
      "min": 300,
      "max": 800,
      "step": 10,
      "default": 500
    },
    {
      "id": "mobile-height",
      "label": "Mobile image height (px)",
      "type": "range",
      "min": 200,
      "max": 600,
      "step": 10,
      "default": 350
    }
  ],
  "presets": [
    {
      "name": "New hero collection"
    }
  ]
}
{% endschema %}
