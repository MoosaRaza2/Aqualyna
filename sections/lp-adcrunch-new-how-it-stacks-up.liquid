{{ 'lp-adcrunch-new-how-it-stacks-up.css' | asset_url | stylesheet_tag }}

<section class="lp-how-it-stacks-up" id="lp-section-{{ section.id }}">
  <div class="lp-how-it-stacks-up__container">
    {% if section.settings.overline != blank %}
      <span class="lp-how-it-stacks-up__overline">{{ section.settings.overline }}</span>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="lp-how-it-stacks-up__heading">{{ section.settings.heading | newline_to_br }}</h2>
    {% endif %}

    <div class="lp-how-it-stacks-up__table-wrapper">
      <table class="lp-how-it-stacks-up__table">
        <thead>
          <tr class="lp-how-it-stacks-up__header-row">
            <th class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--header">{{ section.settings.col_1_label }}</th>
            <th class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--header">{{ section.settings.col_2_label | newline_to_br }}</th>
            <th class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--header">{{ section.settings.col_3_label | newline_to_br }}</th>
            <th class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--header">{{ section.settings.col_4_label | newline_to_br }}</th>
            <th class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--header lp-how-it-stacks-up__cell--brand-header">{{ section.settings.col_brand_label | newline_to_br }}</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr class="lp-how-it-stacks-up__row" {{ block.shopify_attributes }}>
              <td class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--feature">{{ block.settings.feature_name }}</td>
              <td class="lp-how-it-stacks-up__cell cell-bottom" style="color:black;">{{ block.settings.val_1 }}</td>
              <td class="lp-how-it-stacks-up__cell cell-bottom" style="color:black;">{{ block.settings.val_2 }}</td>
              <td class="lp-how-it-stacks-up__cell cell-bottom" style="color:black;">{{ block.settings.val_3 }}</td>
              <td class="lp-how-it-stacks-up__cell lp-how-it-stacks-up__cell--brand">{{ block.settings.val_brand }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('td.lp-how-it-stacks-up__cell').forEach(function (td) {
      var text = td.textContent;
      if (text.includes('✓')) {
        td.style.color = '#2E7D52';
      } else if (text.includes('✕') || text.includes('✗') || /\bX\b/.test(text)) {
        td.style.color = '#C94545';
      }
    });
  });
</script>

