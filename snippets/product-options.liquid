{%- liquid
  assign color_t = 'products.color' | t | downcase
  assign out_of_stock_t = 'products.out_of_stock' | t

  assign current_variant = product.selected_or_first_available_variant

  if block_settings
    assign variant_style = block_settings['variant-style']
    assign size_chart_content = block_settings['size-chart-content']
    assign size_chart_enabled = block_settings['size-chart-enabled']
    assign size_chart_option = block_settings['size-chart-option'] | strip | downcase
    assign swatches_enabled = block_settings['swatches-enabled']
  endif

  unless unique_handle
    assign unique_id = id
  else
    assign unique_id = unique_handle | append: '-' | append: id
  endunless
-%}

{%- liquid
  unless settings['quick-add--enabled']
    render 'section-assets', name: 'product-options', type: 'script'
  endunless
-%}

<product-options-root
  class="product-options--root"
  data-handle="{{ product.handle }}"
  data-id="{{ id }}"
  style="display:block;"
>
  {% assign target_collections = 'aura-hair-extension,ultra-narrow-clip-in-hair-extensions,ponytails,aqualyna-samples' %}
  {% assign current_collection_handle = null %}

  {% for collection in product.collections %}
    {% if target_collections contains collection.handle %}
      {% assign current_collection_handle = collection.handle %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if current_collection_handle %}
    <!-- Color Variant Picker -->
    <div class="color-variants">
      {% assign current_collection = collections[current_collection_handle] %}
      {%- liquid
        assign swatch_order_raw = '1 Black Sample Clip In Hair Extension|||1N Natural Black Sample Clip In Hair Extension|||1B Soft Black Sample Clip In Hair Extension|||1B/4 Duo Tone Sample Clip In Hair Extension|||1B/4 Balayage Sample Clip In Hair Extension|||Pacific Balayage Sample Clip In Hair Extension|||2 Dark Brown Sample Clip In Hair Extension|||4/12 Duo Tone Sample Clip In Hair Extension|||4/12 Balayage Sample Clip In Hair Extension|||4 Medium Brown Sample Clip In Hair Extension|||6 Light Brown Sample Clip In Hair Extension|||33 Dark Copper Red Sample Clip In Hair Extension|||8/24 Duo Tone Sample Clip In Hair Extension|||8/24 Balayage Sample Clip In Hair Extension|||18/22 Duo Tone Sample Clip In Hair Extension|||8AB/60A Rooted Sample Clip In Hair Extension|||Arctic Rooted Sample Clip In Hair Extension|||Arabian Root Tap Sample Clip In Hair Extension - Warm Brown Golden Blonde|||Como Root Tap Sample Clip In Hair Extension - Dark Brown Beige Blonde|||Erie Root Tap Sample Clip In Hair Extension - Light Brown Beige Blonde|||Echo Root Tap Sample Clip In Hair Extension - Medium Brown Beige Blonde|||Tahoe Root Tap Sample Clip In Hair Extension - Beige Blonde|||Victoria Root Tap Sample Clip In Hair Extension - Medium Brown Golden Brown|||Atlantic Duo Tone Sample Clip In Hair Extension|||16 Blonde Sample Clip In Hair Extension|||24 Light Golden Blonde Sample Clip In Hair Extension|||60 Most Platinum Blonde Sample Clip In Hair Extension|||60A Most Platinum Ash Blonde Sample Clip In Hair Extension|||62 Icy Blonde Sample Clip In Hair Extension'
        assign swatch_order = swatch_order_raw | split: '|||'
        assign rendered_handles = '|'
      -%}
      {%- comment -%} Pass 1: list order; match full product title (case-insensitive). Unlisted → pass 2 (end). {%- endcomment -%}
      {% for ordered_title in swatch_order %}
        {% assign ordered_title_norm = ordered_title | strip | downcase %}
        {% for swatch_product in current_collection.products %}
          {% assign handle_marker = '|' | append: swatch_product.handle | append: '|' %}
          {% unless rendered_handles contains handle_marker %}
            {% assign title_parts = swatch_product.title | split: ' - ' %}
            {% assign tooltip_text = '' %}
            {% if title_parts.size > 1 %}
              {% for part in title_parts %}
                {% unless forloop.first %}
                  {% if tooltip_text != '' %}
                    {% assign tooltip_text = tooltip_text | append: ' - ' | append: part %}
                  {% else %}
                    {% assign tooltip_text = part %}
                  {% endif %}
                {% endunless %}
              {% endfor %}
            {% endif %}
            {% assign full_title_norm = swatch_product.title | strip | downcase %}
            {% if full_title_norm == ordered_title_norm %}
              {% assign swatch_display_title = swatch_product.title %}
              {% assign is_active = false %}
              {% if swatch_product.handle == product.handle %}
                {% assign is_active = true %}
              {% endif %}
              <a
                href="{{ swatch_product.url }}"
                class="color-swatch--wrapper"
                data-swatch-title="{{ swatch_display_title | escape }}"
                data-swatch-key="{{ swatch_display_title | handleize }}"
              >
                <div
                  class="color-swatch{% if is_active %} active{% endif %}"
                  style="background-image: url({{ swatch_product.featured_image | img_url: '100x100' }});"
                  data-product-title="{{ swatch_product.title | escape }}"
                  data-swatch-title="{{ swatch_display_title | escape }}"
                  data-swatch-key="{{ swatch_display_title | handleize }}"
                ></div>
                {% if tooltip_text != '' %}
                  <span class="color-swatch--tooltip">{{ tooltip_text }}</span>
                {% endif %}
              </a>
              {% assign rendered_handles = rendered_handles | append: swatch_product.handle | append: '|' %}
              {% break %}
            {% endif %}
          {% endunless %}
        {% endfor %}
      {% endfor %}
      {%- comment -%} Pass 2: remaining swatches in collection order {%- endcomment -%}
      {% for swatch_product in current_collection.products %}
        {% assign handle_marker = '|' | append: swatch_product.handle | append: '|' %}
        {% unless rendered_handles contains handle_marker %}
          {% assign is_active = false %}
          {% if swatch_product.handle == product.handle %}
            {% assign is_active = true %}
          {% endif %}
          {% assign title_parts = swatch_product.title | split: ' - ' %}
          {% assign tooltip_text = '' %}
          {% if title_parts.size > 1 %}
            {% for part in title_parts %}
              {% unless forloop.first %}
                {% if tooltip_text != '' %}
                  {% assign tooltip_text = tooltip_text | append: ' - ' | append: part %}
                {% else %}
                  {% assign tooltip_text = part %}
                {% endif %}
              {% endunless %}
            {% endfor %}
          {% endif %}
          {% assign swatch_display_title = swatch_product.title %}
          <a
            href="{{ swatch_product.url }}"
            class="color-swatch--wrapper"
            data-swatch-title="{{ swatch_display_title | escape }}"
            data-swatch-key="{{ swatch_display_title | handleize }}"
          >
            <div
              class="color-swatch{% if is_active %} active{% endif %}"
              style="background-image: url({{ swatch_product.featured_image | img_url: '100x100' }});"
              data-product-title="{{ swatch_product.title | escape }}"
              data-swatch-title="{{ swatch_display_title | escape }}"
              data-swatch-key="{{ swatch_display_title | handleize }}"
            ></div>
            {% if tooltip_text != '' %}
              <span class="color-swatch--tooltip">{{ tooltip_text }}</span>
            {% endif %}
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  {% endif %}
  {%- unless product.has_only_default_variant -%}
    <div class="product-options--container">
      {%- for option in product.options_with_values -%}
        <div class="product-options--option" data-index="{{ forloop.index0 }}">
          {%- liquid
            assign option_name = option.name | strip | downcase
            assign option_name_display = option_name | remove: 'length' | remove: 'weight' | remove: 'and' | strip

            if swatches_enabled and option_name == color_t
              render 'radios', option: option, id: unique_id, is_swatches: true
            elsif variant_style == 'dropdowns'
              render 'disclosure', display_label: true, label_name: option_name_display, option_names: option.values, current_value: option.selected_value, id: unique_id, type: 'option-picker'
            else
              render 'radios', option: option, id: unique_id
            endif

            comment
              "The size chart link gets moved with JS"
            endcomment

            if size_chart_enabled and size_chart_option == option_name
              render 'product-size-chart', size_chart_content: size_chart_content
            endif
          -%}
        </div>
      {%- endfor -%}
    </div>

    <noscript>
      <select class="product-options--select-noscript" name="id">
        {% for variant in product.variants %}
          <option
            value="{{ variant.id }}"
            data-sku="{{ variant.sku }}"
            {% if variant == current_variant %}
              selected
            {% elsif variant.available == false %}
              disabled
            {% endif %}
          >
            {{ variant.title -}}
            {%- if variant.available == false %} ({{ out_of_stock_t }}){% endif %}
          </option>
        {% endfor %}
      </select>
    </noscript>
  {%- endunless -%}

  <script type="application/json" id="variant--json-{{ unique_id }}">
    {{- product.variants | json -}}
  </script>
  <script type="application/json" id="variant-first--json-{{ unique_id }}">
    {{- current_variant.options | json -}}
  </script>
</product-options-root>
