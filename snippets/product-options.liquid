{%- liquid
  assign color_t = 'products.color' | t | downcase
  assign out_of_stock_t = 'products.out_of_stock' | t

  assign current_variant = product.selected_or_first_available_variant

  if block_settings
    assign variant_style = block_settings['variant-style']
    assign size_chart_content = block_settings['size-chart-content']
    assign size_chart_enabled = block_settings['size-chart-enabled']
    assign size_chart_option = block_settings['size-chart-option'] | strip | downcase
    assign swatches_enabled = block_settings['swatches-enabled']
  endif

  unless unique_handle
    assign unique_id = id
  else
    assign unique_id = unique_handle | append: '-' | append: id
  endunless
-%}

{%- liquid
  unless settings['quick-add--enabled']
    render 'section-assets', name: 'product-options', type: 'script'
  endunless
-%}

<product-options-root
  class="product-options--root"
  data-handle="{{ product.handle }}"
  data-id="{{ id }}"
  style="display:block;"
>
  {% assign target_collections = 'aura-hair-extension,ultra-narrow-clip-in-hair-extensions,ponytails,aqualyna-samples' %}
  {% assign current_collection_handle = null %}

  {% for collection in product.collections %}
    {% if target_collections contains collection.handle %}
      {% assign current_collection_handle = collection.handle %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if current_collection_handle %}
    <!-- Color Variant Picker -->
    {% assign is_adcrunch = false %}
    {% if template_suffix == 'adcrunch-new' %}
      {% assign is_adcrunch = true %}
    {% endif %}

    {% if is_adcrunch %}
      <div class="shade-picker">
        <div class="shade-picker__header">
          <span class="shade-picker__label">SELECT YOUR SHADE</span>
          <a style="font-size:12px;color:#3EA8AD; font-weight:600;" href="/pages/consultation" class="shade-picker__color-match">Not sure? Free color match →</a>
        </div>

        <div class="shade-picker__filters" role="group" aria-label="Filter by shade family">
          {% assign shade_filters = 'All,Black,Brown,Blonde,Balayage,Rooted,Red' | split: ',' %}
          {% for filter in shade_filters %}
            <button
              class="shade-filter-btn{% if filter == 'All' %} active{% endif %}"
              data-filter="{{ filter | downcase | replace: '-', '' | replace: ' ', '' }}"
              type="button"
            >{{ filter }}</button>
          {% endfor %}
        </div>

        {% assign current_collection = collections[current_collection_handle] %}
        <div class="shade-picker__swatches" id="shade-swatches-{{ product.id }}">
          {% for swatch_product in current_collection.products %}
            {% assign is_active = false %}
            {% if swatch_product.handle == product.handle %}
              {% assign is_active = true %}
            {% endif %}
            {%- assign shade_value = swatch_product.metafields.custom.shades | downcase | strip -%}
            <a
              href="{{ swatch_product.url }}"
              title="{{ swatch_product.title }}"
              class="shade-swatch-link{% if is_active %} active{% endif %}"
              data-product-title="{{ swatch_product.title }}"
              data-shade="{{ shade_value }}"
            >
              <div
                class="shade-swatch{% if is_active %} active{% endif %}"
                style="background-image: url({{ swatch_product.featured_image | img_url: '100x100' }});"
              ></div>
            </a>
          {% endfor %}
        </div>

        <div class="shade-picker__selected">
          {% assign selected_product = current_collection.products | where: 'handle', product.handle | first %}
          {% if selected_product %}
            <span>Selected: <strong>{{ selected_product.title }}</strong></span>
          {% else %}
            <span>Selected: <strong>{{ product.title }}</strong></span>
          {% endif %}
        </div>
      </div>

      <script>
        (function () {
          var swatchesEl = document.getElementById('shade-swatches-{{ product.id }}');
          if (!swatchesEl) return;
          var picker     = swatchesEl.closest('.shade-picker');
          if (!picker) return;

          var filterBtns = picker.querySelectorAll('.shade-filter-btn');
          var swatches   = picker.querySelectorAll('.shade-swatch-link');

          filterBtns.forEach(function (btn) {
            btn.addEventListener('click', function () {
              var filter = btn.getAttribute('data-filter');

              filterBtns.forEach(function (b) { b.classList.remove('active'); });
              btn.classList.add('active');

              swatches.forEach(function (swatch) {
                if (filter === 'all') {
                  swatch.style.display = '';
                } else {
                  var shadeRaw = (swatch.getAttribute('data-shade') || '').toLowerCase();
                  var shades   = shadeRaw.split(',').map(function (s) {
                    return s.trim().replace(/[^a-z0-9]/g, '');
                  });
                  swatch.style.display = shades.indexOf(filter) === -1 ? 'none' : '';
                }
              });
            });
          });
        })();
      </script>
    {% else %}
      <div class="color-variants">
        {% assign current_collection = collections[current_collection_handle] %}
        {% for swatch_product in current_collection.products %}
          {% assign is_active = false %}
          {% if swatch_product.handle == product.handle %}
            {% assign is_active = true %}
          {% endif %}
          <a href="{{ swatch_product.url }}" title="{{ swatch_product.title }}">
            <div
              class="color-swatch{% if is_active %} active{% endif %}"
              style="background-image: url({{ swatch_product.featured_image | img_url: '100x100' }});"
              data-product-title="{{ swatch_product.title }}"
            ></div>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
  {%- unless product.has_only_default_variant -%}
    <div class="product-options--container">
      {%- for option in product.options_with_values -%}
        <div class="product-options--option" data-index="{{ forloop.index0 }}">
          {%- liquid
            assign option_name = option.name | strip | downcase

            if swatches_enabled and option_name == color_t
              render 'radios', option: option, id: unique_id, is_swatches: true
            elsif variant_style == 'dropdowns'
              render 'disclosure', display_label: true, label_name: option_name, option_names: option.values, current_value: option.selected_value, id: unique_id, type: 'option-picker'
            else
              render 'radios', option: option, id: unique_id
            endif

            comment
              "The size chart link gets moved with JS"
            endcomment

            if size_chart_enabled and size_chart_option == option_name
              render 'product-size-chart', size_chart_content: size_chart_content
            endif
          -%}
        </div>
      {%- endfor -%}
    </div>

    <noscript>
      <select class="product-options--select-noscript" name="id">
        {% for variant in product.variants %}
          <option
            value="{{ variant.id }}"
            data-sku="{{ variant.sku }}"
            {% if variant == current_variant %}
              selected
            {% elsif variant.available == false %}
              disabled
            {% endif %}
          >
            {{ variant.title -}}
            {%- if variant.available == false %} ({{ out_of_stock_t }}){% endif %}
          </option>
        {% endfor %}
      </select>
    </noscript>
  {%- endunless -%}

  <script type="application/json" id="variant--json-{{ unique_id }}">
    {{- product.variants | json -}}
  </script>
  <script type="application/json" id="variant-first--json-{{ unique_id }}">
    {{- current_variant.options | json -}}
  </script>
</product-options-root>
